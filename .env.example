# Copie este arquivo para .env e configure suas variáveis locais

# ============================================
# OLLAMA - IA Generativa Local
# ============================================
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=llama3
# Para modelo mais rápido, use: llama3.2:3b
# OLLAMA_MODEL=llama3.2:3b

OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=30m

# ============================================
# AGENTE - Monitoramento Operacional
# ============================================
# Quantidade de eventos recentes para análise
AGENT_EVENT_LIMIT=12

# ============================================
# CÂMERA - Fonte de Vídeo
# ============================================
# Opção 1: Câmera Local
# CAMERA_SOURCE=0

# Opção 2: Stream Público (Caltrans)
CAMERA_SOURCE=https://wzmedia.dot.ca.gov/D11/C214_SB_5_at_Via_De_San_Ysidro.stream/playlist.m3u8

# Opção 3: Câmera IP
# CAMERA_SOURCE=rtsp://192.168.1.100:554/stream

CAMERA_RECONNECT_SECONDS=5

# ============================================
# PROJETO - Configurações Gerais
# ============================================
DEBUG=False
DB_PATH=detections.db
SAVE_DIR=static/captures

# ============================================
# YOLO - Detecção de Objetos
# ============================================
CONFIDENCE_THRESHOLD=0.45
MIN_CONSECUTIVE_FRAMES=3
ALERT_COOLDOWN_SECONDS=20
